# Maintainer: Aniketh T S <anikethtsts@gmail.com>
pkgname=scx_quicksched
pkgver=0.2.0
pkgrel=1
pkgdesc="Latency-optimized sched_ext CPU scheduler (Quicksched)"
arch=('x86_64' 'aarch64')
url="https://github.com/AnikethTS/Quicksched"
license=('GPL2')
depends=('libbpf' 'ncurses')
makedepends=('clang' 'gcc' 'make' 'pkgconf' 'bpf' 'linux-headers')
backup=()
source=("$pkgname-$pkgver.tar.gz::$url/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('SKIP')

build() {
    cd "Quicksched-$pkgver"
    make
}

package() {
    cd "Quicksched-$pkgver"
    make install DESTDIR="$pkgdir" PREFIX=/usr UNITDIR=/usr/lib/systemd/system
}
