# ── paths & constants ─────────────────────────────────────────────────────────
SELF = Path(__file__).resolve()
BINARY = SELF.parent.parent / "scx_quicksched"
HISTORY = 60  # sparkline samples

PRESETS = {
    "Gaming": dict(mem=10, io=5, nice=-5, batch=25),
    "Desktop": dict(mem=0, io=0, nice=-10, batch=50),
    "Server": dict(mem=20, io=15, nice=-15, batch=75),
    "Battery": dict(mem=5, io=5, nice=-15, batch=25),
}
PSI_OPTS = [("Off", 0), ("5%", 5), ("10%", 10), ("20%", 20), ("30%", 30)]
NICE_OPTS = [("Default", -1), ("-5", -5), ("-10", -10), ("-15", -15), ("Disabled", -22)]
BATCH_OPTS = [("Default", -1), ("25%", 25), ("50%", 50), ("75%", 75), ("100%", 100)]

# Unicode block chars for sparklines (index 0 = empty, 8 = full)
_BLOCKS = " ▁▂▃▄▅▆▇█"


def sparkline(history: deque, max_val: float = 0.0) -> str:
    """Return a fixed-width sparkline string from a deque of floats."""
    if not history:
        return "─" * 20
    mv = max_val or max(history) or 1.0
    return "".join(_BLOCKS[min(8, int(v * 8 / mv))] for v in history)


# ── CSS ───────────────────────────────────────────────────────────────────────
_BASE_CSS = b"""
window { background-color: #12141a; color: #dddde8; }
.panel { background-color: #1a1d27; border-radius: 8px; padding: 10px; }
.section-title { font-weight: bold; font-size: 11px; color: #8888aa; }
